             XFixesIntersectRegion (dpy, cw->borderClip, cw->borderClip, cw->borderSize);
             XFixesSetPictureClipRegion (dpy, paint_buffer, 0, 0, cw->borderClip);
+            if (is_liquid_glass_window (cw))
